import control
import math
import matplotlib.pyplot as plt
import numpy as np

physical_params = {
    "l" : 0.5,  # length of the arm
    "m" : 2.0,  # mass of the arm
    "k" : [50.0], # spring constants
    "kl" : [2.0], #spring lengths
    "kp" : [(-3, 0)], # spring positions
    "damping" : 0.9 # damping coefficient
}


running_params = {
    "angle" : 0.0,
    "angular_velocity" : 0.0,
    "time_step" : 0.01,
    "control_force" : 35.0
}

class ControlBase():
    def __init__(self, physical_params, running_params):
        self.physical_params = physical_params
        self.running_params = running_params

    def arm_force(self, angle, angular_velocity=0):
        l, m, k, kl, kp, damping = map(self.physical_params.get, ("l", "m", "k", "kl", "kp", "damping"))
        force = 0

        for spring in range(len(kp)):
            sum_distance = math.sqrt(
            ((((l)*(math.cos(angle)))-kp[spring][0]))**2 +
            (((l)*(math.sin(angle))-kp[spring][1]))**2 
            ) - kl[spring]

            f_spring = k[spring] * sum_distance

            force += f_spring * math.sin(angle) / l

        #gravity component
        f_gravity = m * 9.81 * math.cos(angle) / l
        force -= f_gravity
        
        # damping component
        f_damping = damping * angular_velocity
        force -= f_damping
        
        return force

    def velocity_update(self, current_velocity, force, time_step):
        return current_velocity + (force * time_step)

    def angle_update(self, current_angle, current_velocity, time_step: float):
        if current_angle + (current_velocity * time_step) > 2*math.pi:
            return (current_angle + (current_velocity * time_step)) - 2*math.pi
        return current_angle + (current_velocity * time_step)
    
    def run(self, time_limit):
        time_steps = int(time_limit / self.running_params["time_step"])
        velocity = []
        position = []
        for step in range(int(time_limit / self.running_params["time_step"])): #this needs to change as time steps are only intergers
            current_angle = self.running_params["angle"]
            current_velocity = self.running_params["angular_velocity"]
            force = self.arm_force(current_angle, current_velocity) + self.running_params["control_force"]
            new_velocity = self.velocity_update(current_velocity, force, self.running_params["time_step"])
            new_angle = self.angle_update(current_angle, new_velocity, self.running_params["time_step"])

            self.running_params["angle"] = new_angle
            self.running_params["angular_velocity"] = new_velocity
            velocity.append(new_velocity)
            position.append(new_angle)

        return velocity, position, range(int(time_limit / self.running_params["time_step"]))


if __name__ == "__main__":
    control_base = ControlBase(physical_params, running_params)
    force_values = []
    angles = []
    time_limit = 10.0  # seconds
    velocity, position, time_steps = control_base.run(time_limit=time_limit)


    
    plt.figure()
    plt.plot(range(int(time_limit / running_params["time_step"])), velocity)
    plt.xlabel('Time Steps')
    plt.ylabel('Angular Velocity (rad/s)')
    plt.title('Arm Angular Velocity vs Time')
    plt.grid(True)
    plt.show()

    plt.figure()
    plt.plot(range(int(time_limit / running_params["time_step"])), position)
    plt.xlabel('Time Steps')
    plt.ylabel('Angle (radians)')
    plt.title('Arm Angle vs Time')
    plt.grid(True)
    plt.show()

    